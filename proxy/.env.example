# Existing local proxy settings
LOOM_ADDR=127.0.0.1:8080
LOOM_DB=loom-cache.sqlite
LOOM_CACHE=on
OPENAI_UPSTREAM=https://api.openai.com
ANTHROPIC_UPSTREAM=https://api.anthropic.com

# Auth/settings database. If omitted, the proxy still runs and auth routes return 503.
DATABASE_URL=postgres://agenttrace:agenttrace@localhost:5432/agenttrace

# HS256 JWT secret, minimum 32 bytes.
JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ISSUER=agenttrace
JWT_AUDIENCE=agenttrace-app

# AES-GCM key derivation secret for stored LLM API keys.
AGENTTRACE_KEYS_SECRET=replace-with-a-separate-32-plus-byte-secret

# Optional Google OAuth/OIDC.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8080/api/auth/oauth/google/callback
